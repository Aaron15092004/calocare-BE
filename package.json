{
  "name": "calovie-be",
  "version": "1.0.0",
  "description": "CaloVie Backend API - Node.js + Express + MongoDB",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "ingest:usda": "ts-node --transpile-only src/scripts/ingest-usda.ts",
    "embed:foods": "ts-node --transpile-only src/scripts/embed-existing-foods.ts",
    "embed:recipes": "ts-node --transpile-only src/scripts/embed-existing-recipes.ts",
    "patch:usda-input-foods": "ts-node --transpile-only src/scripts/patch-usda-input-foods.ts",
    "import:fatsecret-vn": "ts-node --transpile-only src/scripts/import-fatsecret-vn.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@payos/node": "^2.0.5",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "stream-json": "^2.1.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/stream-json": "^1.7.8",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
